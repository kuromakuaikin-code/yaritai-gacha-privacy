{
  "expo": {
    "name": "家の手入れ記録",
    "description": "家電・設備の掃除・交換・点検履歴と次回目安を記録するアプリ",
    "slug": "ouchi-mente",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ouchimente",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ienoteire.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ienoteire.app",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E8B84"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-iap",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#F7F9F8"
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "登録したメンテナンス項目や実施記録に写真を添付するために、写真ライブラリを使用します。",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "c71c30fe-65c3-4f4f-ad3d-f606fa6558e3"
      }
    }
  }
}
